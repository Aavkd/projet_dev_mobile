{
  "expo": {
    "name": "Click & Collect",
    "slug": "click-and-collect-mobile",
    "scheme": "clickcollect",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.clickcollect.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image-picker",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
