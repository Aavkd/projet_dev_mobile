# Expo public env vars for Appwrite
# Copy to mobile/.env and update values

EXPO_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=
EXPO_PUBLIC_APPWRITE_DATABASE_ID=

EXPO_PUBLIC_APPWRITE_COLLECTION_USERS=users
EXPO_PUBLIC_APPWRITE_COLLECTION_PRODUCTS=products
EXPO_PUBLIC_APPWRITE_COLLECTION_CATEGORIES=categories
EXPO_PUBLIC_APPWRITE_COLLECTION_ORDERS=orders
EXPO_PUBLIC_APPWRITE_COLLECTION_ORDER_ITEMS=order_items
EXPO_PUBLIC_APPWRITE_COLLECTION_PICKUP_ADDRESSES=pickup_addresses
EXPO_PUBLIC_APPWRITE_COLLECTION_OPENING_HOURS=opening_hours
EXPO_PUBLIC_APPWRITE_COLLECTION_NOTIFICATIONS=notifications

EXPO_PUBLIC_APPWRITE_BUCKET_PRODUCTS=
